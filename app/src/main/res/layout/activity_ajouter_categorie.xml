<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutAjouterCategorie"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F2F2"
    android:padding="24dp">

    <!-- Retour -->
    <TextView
        android:id="@+id/textRetour"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Retour"
        android:textSize="18sp"
        android:textColor="#333333"
        android:padding="8dp" />

    <!-- Titre -->
    <TextView
        android:id="@+id/textTitreAjouterCategorie"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ajouter une catégorie"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#222222"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="32dp" />

    <!-- Champ -->
    <EditText
        android:id="@+id/champNomCategorie"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:hint="Nom de la catégorie"
        android:textSize="18sp"
        android:background="#FFFFFF"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp" />

    <!-- Bouton -->
    <TextView
        android:id="@+id/btnAjouter"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="Ajouter la catégorie"
        android:textSize="20sp"
        android:textColor="#000000"
        android:gravity="center"
        android:background="#FFFFFF" />

</LinearLayout>