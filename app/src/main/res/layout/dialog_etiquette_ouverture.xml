<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutEtiquette"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="10dp">

    <TextView
        android:id="@+id/textTitreEtiquette"
        android:layout_width="240dp"
        android:layout_height="40dp"
        android:text="OUVERTURE PRODUIT"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="#000000"
        android:gravity="center"
        android:background="@drawable/border_black"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="62dp"
            android:layout_height="62dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#000000"
            android:layout_marginEnd="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="H"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="28sp" />

            <TextView
                android:id="@+id/textJourEtiquette"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MARDI"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="168dp"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textProduitEtiquette"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Produit :"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/textCategorieEtiquette"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Catégorie :"
                android:textColor="#000000"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/textDateOuvertureEtiquette"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ent./Fab. :"
                android:textColor="#000000"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/textDateLimiteEtiquette"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DLC :"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/textDureeEtiquette"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Durée :"
                android:textColor="#000000"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/textUtilisateurEtiquette"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Par :"
                android:textColor="#000000"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>