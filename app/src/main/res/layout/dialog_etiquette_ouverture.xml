<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutEtiquette"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="20dp">

    <TextView
        android:id="@+id/textTitreEtiquette"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ÉTIQUETTE OUVERTURE"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/textProduitEtiquette"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Produit :"
        android:textSize="17sp"
        android:textColor="#000000"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/textCategorieEtiquette"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Catégorie :"
        android:textSize="16sp"
        android:textColor="#333333"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/textDateOuvertureEtiquette"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ouvert le :"
        android:textSize="16sp"
        android:textColor="#000000"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/textDateLimiteEtiquette"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="À consommer avant :"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#8A1F1F"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/textDureeEtiquette"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Durée après ouverture :"
        android:textSize="15sp"
        android:textColor="#333333"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/textUtilisateurEtiquette"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ouvert par :"
        android:textSize="15sp"
        android:textColor="#333333" />

</LinearLayout>