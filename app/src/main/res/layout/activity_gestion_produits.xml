<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutGestionProduits"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0D8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        android:layout_gravity="center_horizontal"
        android:orientation="vertical">

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:background="#D90718"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <TextView
                android:id="@+id/textRetour"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Retour"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed" />

            <TextView
                android:id="@+id/textTitreGestionProduits"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Gestion des produits"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed" />

        </LinearLayout>

        <!-- CONTENU -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/btnDatesPeremption"
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:gravity="center_vertical"
                android:text="Définir les dates de péremption"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed"
                android:background="#008F6A"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="18dp" />

            <TextView
                android:id="@+id/btnAjouterCategorie"
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:gravity="center_vertical"
                android:text="Ajouter une catégorie"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed"
                android:background="#008F6A"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="18dp" />

            <TextView
                android:id="@+id/btnModifierCategorie"
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:gravity="center_vertical"
                android:text="Modifier une catégorie"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed"
                android:background="#008F6A"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="18dp" />

            <TextView
                android:id="@+id/btnSupprimerCategorie"
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:gravity="center_vertical"
                android:text="Supprimer une catégorie"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed"
                android:background="#B22222"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="18dp" />

            <TextView
                android:id="@+id/btnConditionsStockage"
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:gravity="center_vertical"
                android:text="Conditions de stockage"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed"
                android:background="#008F6A"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="18dp" />

            <TextView
                android:id="@+id/btnDeplacerProduitsCategorie"
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:gravity="center_vertical"
                android:text="Déplacer les produits d'une catégorie"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed"
                android:background="#008F6A"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="24dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>