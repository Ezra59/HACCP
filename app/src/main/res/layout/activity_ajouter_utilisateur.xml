<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutAjouterUtilisateur"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2">

    <LinearLayout
        android:layout_width="600dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Retour -->
        <TextView
            android:id="@+id/textRetour"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Retour"
            android:textSize="18sp"
            android:textColor="#333333"
            android:padding="8dp" />

        <!-- Titre -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ajouter un utilisateur"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp" />

        <!-- Prénom -->
        <EditText
            android:id="@+id/NomUtilisateur"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Prénom"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:textSize="18sp"
            android:layout_marginBottom="14dp" />

        <!-- PIN -->
        <EditText
            android:id="@+id/PinUtilisateur"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Code PIN"
            android:inputType="numberPassword"
            android:maxLength="6"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:textSize="18sp"
            android:layout_marginBottom="14dp" />

        <!-- Spinner -->
        <Spinner
            android:id="@+id/spinner"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="#FFFFFF"
            android:padding="10dp"
            android:layout_marginBottom="24dp" />

        <!-- Bouton -->
        <TextView
            android:id="@+id/buttonCreerUtilisateur"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="Créer"
            android:gravity="center"
            android:textSize="20sp"
            android:textColor="#000000"
            android:background="#FFFFFF" />

    </LinearLayout>

</FrameLayout>