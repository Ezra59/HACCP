<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutAjouterUtilisateur"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F2F2"
    android:padding="24dp">

    <TextView
        android:id="@+id/textRetour"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Retour"
        android:textSize="18sp"
        android:textColor="#333333"
        android:padding="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ajouter un utilisateur"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#222222"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp" />

    <EditText
        android:id="@+id/NomUtilisateur"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Prénom"
        android:background="#FFFFFF"
        android:padding="14dp"
        android:textSize="16sp"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/PinUtilisateur"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Code PIN"
        android:inputType="numberPassword"
        android:maxLength="6"
        android:background="#FFFFFF"
        android:padding="14dp"
        android:textSize="16sp"
        android:layout_marginBottom="12dp" />

    <Spinner
        android:id="@+id/spinner"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:background="#FFFFFF"
        android:padding="10dp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/buttonCreerUtilisateur"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Créer"
        android:gravity="center"
        android:textSize="17sp"
        android:textColor="#000000"
        android:background="#FFFFFF" />

</LinearLayout>