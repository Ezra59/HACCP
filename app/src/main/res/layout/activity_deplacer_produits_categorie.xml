<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutDeplacerProduitsCategorie"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0D8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        android:layout_gravity="center_horizontal"
        android:orientation="vertical">

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:background="#D90718"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <TextView
                android:id="@+id/textRetour"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Retour"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Déplacer les produits"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed" />

        </LinearLayout>

        <!-- CONTENU -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- SOURCE -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Catégorie source"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#D90718"
                android:fontFamily="sans-serif-condensed"
                android:layout_marginBottom="10dp" />

            <Spinner
                android:id="@+id/spinnerCategorieSource"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="#FFFFFF"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginBottom="28dp" />

            <!-- DESTINATION -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Catégorie de destination"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#D90718"
                android:fontFamily="sans-serif-condensed"
                android:layout_marginBottom="10dp" />

            <Spinner
                android:id="@+id/spinnerCategorieDestination"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="#FFFFFF"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginBottom="32dp" />

            <!-- BOUTON -->

            <TextView
                android:id="@+id/btnDeplacer"
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:text="Déplacer les produits"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed"
                android:gravity="center"
                android:background="#008F6A" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>