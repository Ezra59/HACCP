<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutHub"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0D8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"

        android:layout_gravity="center_horizontal"
        android:orientation="vertical">

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:background="#D90718"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <TextView
                android:id="@+id/utilisateruhub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connecté : utilisateur"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed" />

            <TextView
                android:id="@+id/textTitreHub"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Tableau de bord"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed" />

        </LinearLayout>

        <!-- CONTENU -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="32dp">

            <TextView
                android:id="@+id/datehub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Date du jour"
                android:textSize="18sp"
                android:textColor="#D90718"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed"
                android:layout_marginBottom="32dp" />

            <!-- BOUTONS MENU -->

            <TextView
                android:id="@+id/btnReception"
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:gravity="center_vertical"
                android:text="Réception produit"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed"
                android:background="#008F6A"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="18dp" />

            <TextView
                android:id="@+id/btnOuvrirProduit"
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:gravity="center_vertical"
                android:text="Ouvrir un produit"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed"
                android:background="#008F6A"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="18dp" />

            <TextView
                android:id="@+id/btnHistorique"
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:gravity="center_vertical"
                android:text="Historique"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed"
                android:background="#008F6A"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="18dp" />

            <TextView
                android:id="@+id/btnAdmin"
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:gravity="center_vertical"
                android:text="Administration"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed"
                android:background="#008F6A"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="32dp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/btnTachesHaccp"
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:gravity="center_vertical"
                android:text="Tâches HACCP"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed"
                android:background="#008F6A"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="18dp" />

            <!-- DECONNEXION -->

            <Button
                android:id="@+id/buttonDeconnexion"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:text="Déconnexion"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed"
                android:backgroundTint="#D90718" />



        </LinearLayout>

    </LinearLayout>

</ScrollView>