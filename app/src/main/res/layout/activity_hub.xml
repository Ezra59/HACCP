<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutHub"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F2F2"
    android:padding="24dp">

    <TextView
        android:id="@+id/utilisateruhub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Connecté : utilisateur"
        android:textSize="18sp"
        android:textColor="#333333"
        android:padding="8dp" />

    <TextView
        android:id="@+id/datehub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Date du jour"
        android:textSize="16sp"
        android:textColor="#555555"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:layout_marginBottom="20dp" />

    <TextView
        android:id="@+id/textTitreHub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tableau de bord"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#222222"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/btnReception"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:gravity="center_vertical"
        android:text="Réception produit"
        android:textSize="20sp"
        android:textColor="#222222"
        android:background="#FFFFFF"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginBottom="14dp" />

    <TextView
        android:id="@+id/btnHistorique"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:gravity="center_vertical"
        android:text="Historique"
        android:textSize="20sp"
        android:textColor="#222222"
        android:background="#FFFFFF"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginBottom="14dp" />

    <TextView
        android:id="@+id/btnAdmin"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:gravity="center_vertical"
        android:text="Administration"
        android:textSize="20sp"
        android:textColor="#222222"
        android:background="#FFFFFF"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginBottom="14dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/buttonDeconnexion"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Déconnexion"
        android:textSize="17sp" />

</LinearLayout>