<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2">

    <ScrollView
        android:layout_width="600dp"
        android:layout_height="match_parent"
        android:layout_gravity="center">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/textRetour"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Retour"
                android:textSize="18sp"
                android:textColor="#333333"
                android:padding="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Détail produit"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp" />

            <ImageView
                android:id="@+id/detailImage"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:background="#FFFFFF"
                android:scaleType="fitCenter"
                android:layout_marginBottom="20dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/detailNom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nom produit"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#222222"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/detailLot"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lot :"
                    android:textSize="18sp"
                    android:textColor="#333333"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/detailDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DLC/DDM :"
                    android:textSize="18sp"
                    android:textColor="#333333"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/detailCategorie"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Catégorie :"
                    android:textSize="18sp"
                    android:textColor="#333333"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/detailEnregistrePar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ajouté par :"
                    android:textSize="18sp"
                    android:textColor="#333333"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/detailDateReception"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Date réception :"
                    android:textSize="18sp"
                    android:textColor="#333333"
                    android:layout_marginBottom="6dp" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Commentaire"
                android:textSize="20sp"
                android:textColor="#333333"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/detailCommentaire"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:text=""
                android:textSize="18sp"
                android:textColor="#555555"
                android:background="#FFFFFF"
                android:padding="12dp"
                android:layout_marginBottom="24dp" />

        </LinearLayout>

    </ScrollView>

</FrameLayout>