<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0D8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        android:layout_gravity="center_horizontal"
        android:orientation="vertical">

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:background="#D90718"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <TextView
                android:id="@+id/textRetour"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Retour"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Détail produit"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed" />

        </LinearLayout>

        <!-- CONTENU -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- IMAGE -->

            <ImageView
                android:id="@+id/detailImage"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:background="#FFF0D8"
                android:scaleType="fitCenter"
                android:layout_marginBottom="24dp" />

            <!-- INFOS PRODUIT -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFF0D8"
                android:padding="20dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/detailNom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nom produit"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#D90718"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/detailLot"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lot :"
                    android:textSize="20sp"
                    android:textColor="#333333"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/detailDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DLC/DDM :"
                    android:textSize="20sp"
                    android:textColor="#333333"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/detailCategorie"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Catégorie :"
                    android:textSize="20sp"
                    android:textColor="#333333"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/detailEnregistrePar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ajouté par :"
                    android:textSize="20sp"
                    android:textColor="#333333"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/detailDateReception"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Date réception :"
                    android:textSize="20sp"
                    android:textColor="#333333"
                    android:fontFamily="sans-serif-condensed" />

            </LinearLayout>

            <!-- COMMENTAIRE -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Commentaire"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#D90718"
                android:fontFamily="sans-serif-condensed"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/detailCommentaire"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="100dp"
                android:text=""
                android:textSize="18sp"
                android:textColor="#444444"
                android:fontFamily="sans-serif-condensed"
                android:background="#FFF0D8"
                android:padding="16dp"
                android:layout_marginBottom="24dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>