<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutModifierCategorie"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF0D8">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#D90718"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/textRetour"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="← Retour"
            android:textColor="#FFF0D8"
            android:textStyle="bold"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/textTitreModifierCategorie"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:gravity="center"
            android:text="Modifier une catégorie"
            android:textColor="#FFF0D8"
            android:textStyle="bold"
            android:textSize="20sp" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- CONTENU -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- SPINNER -->
            <Spinner
                android:id="@+id/spinnerCategories"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="#FFF0D8"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginBottom="20dp" />

            <!-- INPUT -->
            <EditText
                android:id="@+id/champNouveauNom"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:hint="Nouveau nom"
                android:textSize="18sp"
                android:textColor="#090A0A"
                android:textColorHint="#666666"
                android:background="#FFF0D8"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp" />

            <!-- BOUTON -->
            <TextView
                android:id="@+id/btnModifier"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Modifier la catégorie"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:gravity="center"
                android:background="#008F6A" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>