<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutModifierCategorie"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F2F2"
    android:padding="24dp">

    <TextView
        android:id="@+id/textRetour"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Retour"
        android:textSize="18sp"
        android:textColor="#333333"
        android:padding="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Modifier une catégorie"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#222222"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp" />

    <Spinner
        android:id="@+id/spinnerCategories"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#FFFFFF"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginBottom="20dp" />

    <EditText
        android:id="@+id/champNouveauNom"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:hint="Nouveau nom"
        android:textSize="18sp"
        android:background="#FFFFFF"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp" />

    <TextView
        android:id="@+id/btnModifier"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="Modifier la catégorie"
        android:textSize="20sp"
        android:textColor="#000000"
        android:gravity="center"
        android:background="#FFFFFF" />

</LinearLayout>