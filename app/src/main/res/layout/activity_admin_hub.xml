<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutAdminHub"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0D8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="vertical">

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:background="#D90718"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <TextView
                android:id="@+id/buttonRetourAdmin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Retour"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed" />

            <TextView
                android:id="@+id/admin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Administration"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed" />

        </LinearLayout>

        <!-- CONTENU -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/utilisateurAdminHub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Connecté : utilisateur"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#D90718"
                android:fontFamily="sans-serif-condensed"
                android:layout_marginBottom="32dp" />

            <!-- GESTION UTILISATEURS -->

            <TextView
                android:id="@+id/gestionUtilisateur"
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:gravity="center_vertical"
                android:text="Gestion des utilisateurs"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed"
                android:background="#008F6A"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="18dp" />

            <!-- GESTION ROUTINES -->

            <TextView
                android:id="@+id/btngestionRoutine"
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:gravity="center_vertical"
                android:text="Gestion des routines"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed"
                android:background="#008F6A"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="18dp" />

            <!-- GESTION PRODUITS -->

            <TextView
                android:id="@+id/btngestionProduit"
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:gravity="center_vertical"
                android:text="Gestion des produits"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed"
                android:background="#008F6A"
                android:paddingStart="24dp"
                android:paddingEnd="24dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>