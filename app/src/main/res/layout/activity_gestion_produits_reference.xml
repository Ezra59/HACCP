<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0D8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="vertical">

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:background="#D90718"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <TextView
                android:id="@+id/textRetour"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Retour"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed" />

            <TextView
                android:id="@+id/textTitreGestionProduitsOuverture"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Gestion des produits (ouverture)"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed" />

        </LinearLayout>

        <!-- CONTENU -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- NOM PRODUIT -->

            <EditText
                android:id="@+id/editNomProduit"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:hint="Nom du produit"
                android:textSize="18sp"
                android:textColor="#222222"
                android:textColorHint="#777777"
                android:background="#E6F4EE"
                android:padding="16dp"
                android:layout_marginBottom="18dp" />

            <!-- SPINNER -->

            <Spinner
                android:id="@+id/spinnerCategorie"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:background="#E6F4EE"
                android:padding="10dp"
                android:layout_marginBottom="18dp" />

            <!-- DUREE -->

            <EditText
                android:id="@+id/editDuree"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:hint="Durée après ouverture (jours)"
                android:inputType="number"
                android:textSize="18sp"
                android:textColor="#222222"
                android:textColorHint="#777777"
                android:background="#E6F4EE"
                android:padding="16dp"
                android:layout_marginBottom="24dp" />

            <!-- BOUTON -->

            <Button
                android:id="@+id/btnAjouter"
                android:layout_width="match_parent"
                android:layout_height="78dp"
                android:text="Ajouter"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed"
                android:backgroundTint="#008F6A"
                android:layout_marginBottom="28dp" />

            <!-- RECYCLER -->

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerProduits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>