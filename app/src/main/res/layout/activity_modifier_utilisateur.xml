<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutModifierUtilisateur"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF0D8">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#D90718"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/textRetour"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="← Retour"
            android:textColor="#FFF0D8"
            android:textStyle="bold"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/textTitre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:gravity="center"
            android:text="Modifier un utilisateur"
            android:textColor="#FFF0D8"
            android:textStyle="bold"
            android:textSize="20sp" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- CONTENU -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- TITRE -->
            <TextView
                android:id="@+id/textListeUtilisateurs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Liste des utilisateurs"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#090A0A"
                android:layout_marginBottom="10dp" />

            <!-- RECYCLER -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerUtilisateurs"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:background="#FFF0D8"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="20dp" />

            <!-- PRENOM -->
            <EditText
                android:id="@+id/editPrenom"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Prénom"
                android:textColor="#090A0A"
                android:textColorHint="#666666"
                android:background="#FFF0D8"
                android:padding="14dp"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <!-- PIN -->
            <EditText
                android:id="@+id/editPin"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Code PIN"
                android:inputType="numberPassword"
                android:maxLength="6"
                android:textColor="#090A0A"
                android:textColorHint="#666666"
                android:background="#FFF0D8"
                android:padding="14dp"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <!-- ROLE -->
            <Spinner
                android:id="@+id/spinnerRole"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="#FFF0D8"
                android:padding="10dp"
                android:layout_marginBottom="20dp" />

            <!-- BOUTON -->
            <Button
                android:id="@+id/buttonModifier"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Modifier"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:background="#008F6A" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>