<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0D8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:background="#D90718"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <Button
                android:id="@+id/buttonRetour"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Retour"
                android:textColor="#FFF0D8"
                android:textStyle="bold"
                android:textSize="16sp"
                android:fontFamily="sans-serif-condensed"
                android:backgroundTint="#008F6A" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Connexion"
                android:gravity="center"
                android:textColor="#FFF0D8"
                android:textSize="30sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed" />

        </LinearLayout>

        <!-- CONTENU -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"

            android:layout_gravity="center_horizontal"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="32dp">

            <TextView
                android:id="@+id/bienvenueMess"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bienvenue"
                android:textSize="34sp"
                android:textStyle="bold"
                android:textColor="#D90718"
                android:fontFamily="sans-serif-condensed"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/loginMess"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Saisissez votre code PIN"
                android:textSize="22sp"
                android:textColor="#D90718"
                android:fontFamily="sans-serif-condensed"
                android:gravity="center"
                android:layout_marginBottom="36dp" />

            <!-- AFFICHAGE PIN -->

            <TextView
                android:id="@+id/textPin"
                android:layout_width="match_parent"
                android:layout_height="85dp"
                android:text="● ● ● ● ● ●"
                android:textSize="42sp"
                android:textStyle="bold"
                android:textColor="#D90718"
                android:fontFamily="sans-serif-condensed"
                android:gravity="center"
                android:background="#F7E4C6"
                android:layout_marginBottom="42dp" />

            <!-- CLAVIER -->

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"

                android:columnCount="3">

                <!-- LIGNE 1 -->

                <Button
                    android:id="@+id/button1"
                    android:layout_width="0dp"
                    android:layout_height="82dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:text="1"
                    android:textColor="#FFF0D8"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:backgroundTint="#008F6A" />

                <Button
                    android:id="@+id/button2"
                    android:layout_width="0dp"
                    android:layout_height="82dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:text="2"
                    android:textColor="#FFF0D8"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:backgroundTint="#008F6A" />

                <Button
                    android:id="@+id/button3"
                    android:layout_width="0dp"
                    android:layout_height="82dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:text="3"
                    android:textColor="#FFF0D8"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:backgroundTint="#008F6A" />

                <!-- LIGNE 2 -->

                <Button
                    android:id="@+id/button4"
                    android:layout_width="0dp"
                    android:layout_height="82dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:text="4"
                    android:textColor="#FFF0D8"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:backgroundTint="#008F6A" />

                <Button
                    android:id="@+id/button5"
                    android:layout_width="0dp"
                    android:layout_height="82dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:text="5"
                    android:textColor="#FFF0D8"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:backgroundTint="#008F6A" />

                <Button
                    android:id="@+id/button6"
                    android:layout_width="0dp"
                    android:layout_height="82dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:text="6"
                    android:textColor="#FFF0D8"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:backgroundTint="#008F6A" />

                <!-- LIGNE 3 -->

                <Button
                    android:id="@+id/button7"
                    android:layout_width="0dp"
                    android:layout_height="82dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:text="7"
                    android:textColor="#FFF0D8"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:backgroundTint="#008F6A" />

                <Button
                    android:id="@+id/button8"
                    android:layout_width="0dp"
                    android:layout_height="82dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:text="8"
                    android:textColor="#FFF0D8"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:backgroundTint="#008F6A" />

                <Button
                    android:id="@+id/button9"
                    android:layout_width="0dp"
                    android:layout_height="82dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:text="9"
                    android:textColor="#FFF0D8"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:backgroundTint="#008F6A" />

                <!-- LIGNE 4 -->

                <Space
                    android:layout_width="0dp"
                    android:layout_height="82dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp" />

                <Button
                    android:id="@+id/button0"
                    android:layout_width="0dp"
                    android:layout_height="82dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:text="0"
                    android:textColor="#FFF0D8"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:backgroundTint="#008F6A" />

                <Button
                    android:id="@+id/buttonDelete"
                    android:layout_width="0dp"
                    android:layout_height="82dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:text="⌫"
                    android:textColor="#FFF0D8"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:backgroundTint="#008F6A" />

            </GridLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>