<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/textNomProduit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Nom produit"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#222222"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/textDateProduit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Date"
        android:textColor="#555555"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/textNomProduit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/textLotProduit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Lot"
        android:textColor="#555555"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/textDateProduit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>