<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutGestionUtilisateurs"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxWidth="700dp"
        android:layout_gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/textRetour"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Retour"
            android:textSize="18sp"
            android:textColor="#333333"
            android:padding="8dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/textTitreGestionUtilisateurs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gestion des utilisateurs"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp" />

        <TextView
            android:id="@+id/ajouterutilisateur"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:gravity="center_vertical"
            android:text="Ajouter un utilisateur"
            android:textSize="20sp"
            android:textColor="#222222"
            android:background="#FFFFFF"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginBottom="14dp" />

        <TextView
            android:id="@+id/modifierUtilisateur"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:gravity="center_vertical"
            android:text="Modifier un utilisateur"
            android:textSize="20sp"
            android:textColor="#222222"
            android:background="#FFFFFF"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginBottom="14dp" />

        <TextView
            android:id="@+id/supprimerUtilisateur"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:gravity="center_vertical"
            android:text="Supprimer un utilisateur"
            android:textSize="20sp"
            android:textColor="#8A1F1F"
            android:background="#FFFFFF"
            android:paddingStart="20dp"
            android:paddingEnd="20dp" />

    </LinearLayout>

</ScrollView>