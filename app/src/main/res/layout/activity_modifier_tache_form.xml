<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0D8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:background="#D90718"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <TextView
                android:id="@+id/textRetour"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Retour"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed" />

            <TextView
                android:id="@+id/textTitreModifierTache"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Modifier tâche"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="#FFF0D8"
                android:fontFamily="sans-serif-condensed" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <EditText
                android:id="@+id/editNomTache"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nom de la tâche"
                android:textColor="#D90718"
                android:textColorHint="#D90718"
                android:textSize="16sp"
                android:fontFamily="sans-serif-condensed"
                android:inputType="text"
                android:padding="16dp"
                android:backgroundTint="#D90718"
                android:layout_marginBottom="24dp" />

            <Spinner
                android:id="@+id/spinnerFrequenceTache"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp" />

            <Spinner
                android:id="@+id/spinnerTypeTache"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="40dp" />

            <Button
                android:id="@+id/btnModifierTache"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Modifier la tâche"
                android:textColor="#FFF0D8"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed"
                android:backgroundTint="#D90718"
                android:padding="16dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>